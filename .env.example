# Directory for compose project files (container-side path)
COMPOSE_DIR=./data/compose

# Host-side path for COMPOSE_DIR (required in Docker so compose commands resolve correctly)
# COMPOSE_HOST_DIR=/path/on/host/to/compose

# Directory for application data (SQLite database)
DATA_DIR=./data

# Docker socket path
DOCKER_SOCKET=/var/run/docker.sock

# Authentication
AUTH_RP_ID=localhost
AUTH_ORIGIN=http://localhost:3005
AUTH_SESSION_SECRET=

# Backup destination directory
BACKUP_DIR=/backups
