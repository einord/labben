# ===========================================
# Labben — Environment Configuration
# Copy this file to .env and adjust the values
# ===========================================

# REQUIRED: Path to your Docker Compose projects on the host
COMPOSE_PATH=/path/to/your/compose/projects

# OPTIONAL: Path to backup destination on the host (e.g. NAS mount)
# Uncomment the backup volume in docker-compose.yml to enable
# BACKUP_PATH=/path/to/backup/destination

# OPTIONAL: Authentication (defaults work for local access)
# Set these when exposing Labben publicly via a domain
# AUTH_RP_ID=labben.example.com
# AUTH_ORIGIN=https://labben.example.com
# AUTH_SESSION_SECRET=replace-with-a-random-string

# OPTIONAL: Encryption key for stored credentials (NPM password, etc.)
# Falls back to AUTH_SESSION_SECRET if not set
# ENCRYPTION_SECRET=replace-with-a-random-string
